## Anti-Patterns

```tsx
// ❌ Swap content on prop change without displayed buffer
<Text>{item.text}</Text>

// ✅ displayed from transition hook
<Text style={animatedStyle}>{displayed.text}</Text>
```

```ts
// ❌ setState in animation callback without runOnJS
withTiming(0, {}, () => { setDisplayed(next); });

// ✅ runOnJS
withTiming(0, {}, (f) => { if (f) runOnJS(setDisplayed)(next); });
```

```ts
// ❌ Read shared value on JS thread
if (opacity.value > 0.5) setVisible(true);

// ✅ useAnimatedReaction or drive UI only via animated styles
```

```ts
// ❌ withSpring for crossfade
incomingOpacity.value = withSpring(1);

// ✅ withTiming for fade
incomingOpacity.value = withTiming(1, { duration: CROSSFADE_MS });
```

```tsx
// ❌ Inline transition orchestration in JSX when hook owns the concern
// ✅ Dedicated use*Transition / use*Animation hook
```

